/* ================= RESPONSIVE ================= */

/* Tablet */
@media (max-width: 992px){

.jobGrid{
    grid-template-columns: repeat(auto-fit, minmax(200px,1fr));
}

h1{
    font-size:40px;
    margin-left:50px;
}

.ul{
    margin-left:50px;
}

.knowbtn{
    margin-left:60px;
}

.img{
    margin-top:-150px;
}

}


/* Mobile */
@media (max-width: 600px){

nav ul{
    flex-direction:column;
    align-items:flex-start;
}

nav ul li a{
    margin-left:0;
    padding:5px 0;
}

.profile{
    margin-left:0;
    margin-top:10px;
}

.jobGrid{
    grid-template-columns:1fr;
}

h1{
    font-size:28px;
    margin-left:20px;
}

.ul{
    margin-left:20px;
}

.knowbtn{
    margin-left:20px;
    width:130px;
}

.img{
    justify-content:center;
    margin-top:20px;
}

.dashboard{
    height:auto;
    padding-bottom:40px;
}

}