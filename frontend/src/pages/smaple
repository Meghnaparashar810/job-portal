/* header

.dashboardHeader{
    display:flex;
    justify-content:space-between;
    align-items:center;
    margin-bottom:30px;
}

.dashboardHeader h2{
    font-size:28px;
}

.profile{
    background:#4f46e5;
    color:white;
    padding:8px 18px;
    border-radius:20px;
    cursor:pointer;
}

/* grid */

.jobGrid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(100px,350px));
    gap:20px;
} 

/* job card */

.jobCard{
    background:white;
    padding:10px;
    border-radius:10px;
    box-shadow:0 5px 15px rgba(0,0,0,0.1);
    transition:0.3s;
}

.jobCard:hover{
    transform:translateY(-5px);
}

.company{
    color:#4f46e5;
    margin-bottom:10px;
} 



.dashboard {
    background-image: url("../assets/image.png");
    background-size: cover;
    background-position: center;
    height: 100vh;
}


nav ul {
    align-items: center;
    padding: 20px;
    display: flex;
    
}

nav ul li a {
    color: rgb(49, 38, 38);
    text-decoration: none;
